#!/bin/sh
set -eu

CMD="${1:-get}"
FILE="/etc/sub-sync/donaters.tsv"

mkdir -p /etc/sub-sync

init_file() {
    if [ ! -s "$FILE" ]; then
        : > "$FILE"
        i=1
        while [ "$i" -le 12 ]; do
            printf '0\t\t\n' >> "$FILE"
            i=$((i + 1))
        done
    fi
}

json_get() {
    init_file
    awk -F '\t' '
    function esc(s) {
        gsub(/\\/,"\\\\",s)
        gsub(/"/,"\\\"",s)
        gsub(/\r/,"",s)
        gsub(/\n/," ",s)
        return s
    }
    BEGIN {
        printf "{\"items\":["
    }
    {
        if (NR > 1) printf ","
        enabled = ($1 == "1") ? "true" : "false"
        printf "{\"row\":%d,\"enabled\":%s,\"nick\":\"%s\",\"url\":\"%s\"}", NR, enabled, esc($2), esc($3)
    }
    END {
        printf "]}\n"
    }
    ' "$FILE"
}

case "$CMD" in
    get|"")
        json_get
        logger -t sub-sync "donaters public get"
        ;;
    *)
        echo '{"ok":false,"error":"read-only helper"}'
        exit 1
        ;;
esac
