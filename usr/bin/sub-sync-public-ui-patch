#!/bin/sh
# SUBSYNC_PUBLIC_UI_PATCH_V166C_NO_PYTHON
set -u

JS="/www/luci-static/resources/view/sub_sync/sub_sync.js"

[ -f "$JS" ] || {
  echo "ERROR: JS not found: $JS"
  exit 1
}

if grep -q 'SUBSYNC_PUBLIC_UI_PATCH_V166C_APPLIED' "$JS" 2>/dev/null; then
  echo "Public UI patch v166c already applied"
  exit 0
fi

B="/root/SUBSYNC-PUBLIC-UI-PATCH-V166C-BEFORE-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$B"
cp -a "$JS" "$B/sub_sync.js.before-v166c"

INJ="/tmp/subsync-public-ui-v166c-inject.$$"
TMP="/tmp/subsync-public-ui-v166c-js.$$"

cat > "$INJ" <<'INJECT_EOF'
/* SUBSYNC_PUBLIC_UI_PATCH_V166C_APPLIED */
(function() {
  'use strict';

  var TELEGRAM = 'https://t.me/+LZDsQJhUfcNhYWEy';

  function addStyle() {
    if (document.getElementById('ss-public-ui-v166c-style')) return;

    var st = document.createElement('style');
    st.id = 'ss-public-ui-v166c-style';
    st.textContent =
      '/* SUBSYNC_DONATERS_PUBLIC_CARDS_V136_INLINE_STYLE */\n' +
      '@keyframes ssPodcopSubV666TitleShineV136 { 0% { background-position: 0% 50%; filter: brightness(1); } 50% { background-position: 100% 50%; filter: brightness(1.18); } 100% { background-position: 0% 50%; filter: brightness(1); } }\n' +
      '@keyframes ssDonatersTitlePulseV136 { 0%, 100% { transform: scale(1); opacity: .94; } 50% { transform: scale(1.018); opacity: 1; } }\n' +
      '.ss-podcop-sub-v666-shine-v166c { display:inline-block; background:linear-gradient(90deg,#38bdf8,#22c55e,#f97316,#e879f9,#38bdf8); background-size:300% 300%; -webkit-background-clip:text; background-clip:text; color:transparent!important; animation:ssPodcopSubV666TitleShineV136 4.2s ease-in-out infinite; font-weight:900; }\n' +
      '.ss-public-help-v166c { margin:12px 0 14px 0; padding:12px 14px; border-radius:14px; border:1px solid rgba(56,189,248,.34); background:rgba(56,189,248,.08); box-shadow:0 8px 24px rgba(0,0,0,.12); }\n' +
      '.ss-public-help-v166c a { font-weight:800; text-decoration:none; }\n' +
      '.ss-donaters-public-v166c { margin:12px 0 14px 0; padding:12px 14px; border-radius:14px; border:1px solid rgba(34,197,94,.32); background:rgba(34,197,94,.08); box-shadow:0 8px 24px rgba(0,0,0,.12); }\n' +
      '.ss-donaters-public-v166c-title { font-weight:900; margin-bottom:8px; animation:ssDonatersTitlePulseV136 2.8s ease-in-out infinite; }\n' +
      '.ss-donaters-public-v166c-row { display:flex; flex-wrap:wrap; gap:8px; }\n' +
      '.ss-donaters-public-v166c-card { padding:7px 10px; border-radius:999px; border:1px solid rgba(255,255,255,.16); background:rgba(255,255,255,.08); font-weight:700; }\n' +
      '.ss-singbox-check-v166c { margin:10px 0 14px 0; padding:10px 12px; border-radius:12px; border:1px solid rgba(148,163,184,.35); opacity:.92; font-size:12px; }\n';

    document.head.appendChild(st);
  }

  function textHas(root, needle) {
    return root && (root.textContent || '').indexOf(needle) !== -1;
  }

  function findMount() {
    var nodes = Array.prototype.slice.call(document.querySelectorAll('.cbi-map, .cbi-section, main, #maincontent, body'));
    for (var i = 0; i < nodes.length; i++) {
      if (textHas(nodes[i], 'Sub Sync') || textHas(nodes[i], 'Podcop Sub') || textHas(nodes[i], 'Podkop')) return nodes[i];
    }
    return document.body;
  }

  function addTitleShine(root) {
    var heads = Array.prototype.slice.call(root.querySelectorAll('h1,h2,h3,.cbi-map-title,.cbi-section h3'));
    heads.forEach(function(h) {
      var t = (h.textContent || '').trim();
      if (/Sub Sync|Podcop Sub|Podkop Sub/i.test(t)) h.classList.add('ss-podcop-sub-v666-shine-v166c');
    });
  }

  function ensureBlocks() {
    addStyle();

    var root = findMount();
    if (!root) return;

    addTitleShine(root);

    if (document.getElementById('ss-public-ui-v166c-block')) return;

    var holder = document.createElement('div');
    holder.id = 'ss-public-ui-v166c-block';
    holder.innerHTML =
      '<div class="ss-public-help-v166c">' +
        '<b class="ss-podcop-sub-v666-shine-v166c">Помощь по Podcop Sub v666</b>: ' +
        '<a href="' + TELEGRAM + '" target="_blank" rel="noreferrer">Telegram</a>' +
      '</div>' +
      '<div class="ss-donaters-public-v166c">' +
        '<div class="ss-donaters-public-v166c-title">Донатеры проекта</div>' +
        '<div class="ss-donaters-public-v166c-row">' +
          '<span class="ss-donaters-public-v166c-card">Спасибо всем, кто поддерживает проект</span>' +
          '<span class="ss-donaters-public-v166c-card">Podcop Sub v666</span>' +
        '</div>' +
      '</div>' +
      '<div class="ss-singbox-check-v166c">Проверка sing-box: <code>/usr/bin/sub-sync-singbox-check</code></div>';

    if (root.firstChild) root.insertBefore(holder, root.firstChild);
    else root.appendChild(holder);
  }

  function boot() {
    ensureBlocks();
    setTimeout(ensureBlocks, 500);
    setTimeout(ensureBlocks, 1500);
    try {
      new MutationObserver(function() { ensureBlocks(); }).observe(document.body, { childList: true, subtree: true });
    } catch(e) {}
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
INJECT_EOF

awk '
  FNR == NR { inj = inj $0 "\n"; next }
  done == 0 && $0 ~ /return[ \t]+view\.extend[ \t]*\(/ {
    printf "%s", inj
    done = 1
  }
  { print }
  END {
    if (done == 0) printf "%s", inj
  }
' "$INJ" "$JS" > "$TMP"

cp -f "$TMP" "$JS"
rm -f "$INJ" "$TMP"

grep -q 'SUBSYNC_PUBLIC_UI_PATCH_V166C_APPLIED' "$JS" || { echo "ERROR: marker not found"; exit 1; }
grep -q 'SUBSYNC_DONATERS_PUBLIC_CARDS_V136_INLINE_STYLE' "$JS" || { echo "ERROR: donor style not found"; exit 1; }
grep -q 'ssPodcopSubV666TitleShineV136' "$JS" || { echo "ERROR: title animation not found"; exit 1; }
grep -q 'https://t.me/+LZDsQJhUfcNhYWEy' "$JS" || { echo "ERROR: Telegram link not found"; exit 1; }

rm -rf /tmp/luci-modulecache/* /tmp/luci-indexcache* /tmp/luci-sessions/* 2>/dev/null || true
/etc/init.d/rpcd restart || true
/etc/init.d/uhttpd restart || true

echo "Public UI patch v166c applied"
echo "BACKUP: $B"
