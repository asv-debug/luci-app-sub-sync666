#!/bin/sh
# SUBSYNC_PUBLIC_UI_PATCH_V166
set -u

JS="/www/luci-static/resources/view/sub_sync/sub_sync.js"

[ -f "$JS" ] || {
  echo "ERROR: JS not found: $JS"
  exit 1
}

if grep -q 'SUBSYNC_PUBLIC_UI_PATCH_V166_APPLIED' "$JS" 2>/dev/null; then
  echo "Public UI patch v166 already applied"
  exit 0
fi

B="/root/SUBSYNC-PUBLIC-UI-PATCH-V166-BEFORE-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$B"
cp -a "$JS" "$B/sub_sync.js.before-v166-public-ui"

python3 - "$JS" <<'PY'
import sys, re, pathlib

path = pathlib.Path(sys.argv[1])
s = path.read_text(errors="ignore")

marker = "SUBSYNC_PUBLIC_UI_PATCH_V166_APPLIED"
if marker in s:
    sys.exit(0)

inject = r'''
/* SUBSYNC_PUBLIC_UI_PATCH_V166_APPLIED */
(function() {
  'use strict';

  var TELEGRAM = 'https://t.me/+LZDsQJhUfcNhYWEy';

  function addStyle() {
    if (document.getElementById('ss-public-ui-v166-style')) return;

    var st = document.createElement('style');
    st.id = 'ss-public-ui-v166-style';
    st.textContent = `
      /* SUBSYNC_DONATERS_PUBLIC_CARDS_V136_INLINE_STYLE */
      @keyframes ssPodcopSubV666TitleShineV136 {
        0% { background-position: 0% 50%; filter: brightness(1); }
        50% { background-position: 100% 50%; filter: brightness(1.18); }
        100% { background-position: 0% 50%; filter: brightness(1); }
      }
      @keyframes ssDonatersTitlePulseV136 {
        0%, 100% { transform: scale(1); opacity: .94; }
        50% { transform: scale(1.018); opacity: 1; }
      }
      .ss-podcop-sub-v666-shine-v166 {
        display: inline-block;
        background: linear-gradient(90deg,#38bdf8,#22c55e,#f97316,#e879f9,#38bdf8);
        background-size: 300% 300%;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent !important;
        animation: ssPodcopSubV666TitleShineV136 4.2s ease-in-out infinite;
        font-weight: 900;
      }
      .ss-public-help-v166 {
        margin: 12px 0 14px 0;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(56,189,248,.34);
        background: rgba(56,189,248,.08);
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
      }
      .ss-public-help-v166 a {
        font-weight: 800;
        text-decoration: none;
      }
      .ss-donaters-public-v166 {
        margin: 12px 0 14px 0;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(34,197,94,.32);
        background: rgba(34,197,94,.08);
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
      }
      .ss-donaters-public-v166-title {
        font-weight: 900;
        margin-bottom: 8px;
        animation: ssDonatersTitlePulseV136 2.8s ease-in-out infinite;
      }
      .ss-donaters-public-v166-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .ss-donaters-public-v166-card {
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.16);
        background: rgba(255,255,255,.08);
        font-weight: 700;
      }
      .ss-singbox-check-v166 {
        margin: 10px 0 14px 0;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(148,163,184,.35);
        opacity: .92;
        font-size: 12px;
      }
    `;
    document.head.appendChild(st);
  }

  function textHas(root, needle) {
    return root && (root.textContent || '').indexOf(needle) !== -1;
  }

  function findMount() {
    var nodes = Array.prototype.slice.call(document.querySelectorAll('.cbi-map, .cbi-section, main, #maincontent, body'));
    for (var i = 0; i < nodes.length; i++) {
      if (textHas(nodes[i], 'Sub Sync') || textHas(nodes[i], 'Podcop Sub') || textHas(nodes[i], 'Podkop')) return nodes[i];
    }
    return document.body;
  }

  function addTitleShine(root) {
    var heads = Array.prototype.slice.call(root.querySelectorAll('h1,h2,h3,.cbi-map-title,.cbi-section h3'));
    heads.forEach(function(h) {
      var t = (h.textContent || '').trim();
      if (/Sub Sync|Podcop Sub|Podkop Sub/i.test(t)) h.classList.add('ss-podcop-sub-v666-shine-v166');
    });
  }

  function ensureBlocks() {
    addStyle();

    var root = findMount();
    if (!root || document.getElementById('ss-public-ui-v166-block')) {
      if (root) addTitleShine(root);
      return;
    }

    addTitleShine(root);

    var holder = document.createElement('div');
    holder.id = 'ss-public-ui-v166-block';

    holder.innerHTML =
      '<div class="ss-public-help-v166">' +
        '<b class="ss-podcop-sub-v666-shine-v166">Помощь по Podcop Sub v666</b>: ' +
        '<a href="' + TELEGRAM + '" target="_blank" rel="noreferrer">Telegram</a>' +
      '</div>' +
      '<div class="ss-donaters-public-v166">' +
        '<div class="ss-donaters-public-v166-title">Донатеры проекта</div>' +
        '<div class="ss-donaters-public-v166-row">' +
          '<span class="ss-donaters-public-v166-card">Спасибо всем, кто поддерживает проект</span>' +
          '<span class="ss-donaters-public-v166-card">Podcop Sub v666</span>' +
        '</div>' +
      '</div>' +
      '<div class="ss-singbox-check-v166">Проверка sing-box доступна через helper: <code>/usr/bin/sub-sync-singbox-check</code></div>';

    if (root.firstChild) root.insertBefore(holder, root.firstChild);
    else root.appendChild(holder);
  }

  function boot() {
    ensureBlocks();
    setTimeout(ensureBlocks, 500);
    setTimeout(ensureBlocks, 1500);
    try {
      new MutationObserver(function() { ensureBlocks(); }).observe(document.body, { childList: true, subtree: true });
    } catch(e) {}
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
'''

# Важно: LuCI view часто делает `return view.extend(...)`; код после return не выполнится.
# Поэтому вставляем patch прямо перед первым `return view.extend`.
m = re.search(r'\breturn\s+view\.extend\s*\(', s)
if m:
    s = s[:m.start()] + inject + "\n" + s[m.start():]
else:
    s = inject + "\n" + s

path.write_text(s)
PY

grep -q 'SUBSYNC_PUBLIC_UI_PATCH_V166_APPLIED' "$JS" || {
  echo "ERROR: patch marker not found after patch"
  exit 1
}

grep -q 'https://t.me/+LZDsQJhUfcNhYWEy' "$JS" || {
  echo "ERROR: Telegram link not found after patch"
  exit 1
}

grep -q 'ssPodcopSubV666TitleShineV136' "$JS" || {
  echo "ERROR: title animation not found after patch"
  exit 1
}

rm -rf /tmp/luci-modulecache/* /tmp/luci-indexcache* /tmp/luci-sessions/* 2>/dev/null || true
/etc/init.d/rpcd restart || true
/etc/init.d/uhttpd restart || true

echo "Public UI patch v166 applied"
echo "BACKUP: $B"
