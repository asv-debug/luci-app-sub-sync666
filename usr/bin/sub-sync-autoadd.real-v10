#!/bin/sh

DATA_DIR="/etc/sub-sync"
SERVERS_FILE="$DATA_DIR/servers.json"
LINKS_FILE="$DATA_DIR/links.txt"
CONF="/etc/sub-sync/autoadd.conf"
REAL="/usr/bin/sub-sync.real"
LOG_TAG="sub-sync-autoadd"

log() {
    logger -t "$LOG_TAG" "$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1"
}

json_escape() {
    echo "$1" | sed 's/\\/\\\\/g;s/"/\\"/g' | tr -d '\n\r'
}

load_conf() {
    [ -f "$CONF" ] || return 0
    # shellcheck disable=SC1090
    . "$CONF"
    ENABLED="${ENABLED:-0}"
    TARGET_SECTION="${TARGET_SECTION:-TEST123}"
    MODE="${MODE:-replace}"
    LIMIT="${LIMIT:-20}"
    USE_PING_FILTER="${USE_PING_FILTER:-1}"
    MAX_PING="${MAX_PING:-700}"
    USE_TRANSPORT_FILTER="${USE_TRANSPORT_FILTER:-0}"
    TRANSPORTS="${TRANSPORTS:-xhttp}"
    USE_PROTO_FILTER="${USE_PROTO_FILTER:-0}"
    PROTOCOLS="${PROTOCOLS:-vless}"
    USE_COUNTRY_FILTER="${USE_COUNTRY_FILTER:-0}"
    COUNTRIES="${COUNTRIES:-}"
    RESTART_PODKOP="${RESTART_PODKOP:-1}"
}

get_json_field() {
    # $1 json object line, $2 field
    printf '%s\n' "$1" | sed 's/.*"'$2'":"\([^"]*\)".*/\1/'
}

get_json_num() {
    printf '%s\n' "$1" | sed 's/.*"'$2'":\([0-9][0-9]*\).*/\1/'
}

csv_has() {
    # $1 csv, $2 value
    local list val item
    list="$1"
    val="$2"
    [ -z "$list" ] && return 1
    OLDIFS="$IFS"
    IFS=','
    for item in $list; do
        item=$(printf '%s' "$item" | sed 's/^ *//;s/ *$//')
        [ "$item" = "$val" ] && { IFS="$OLDIFS"; return 0; }
    done
    IFS="$OLDIFS"
    return 1
}

csv_name_match() {
    # $1 csv words, $2 name
    local list name item low_name low_item
    list="$1"
    name="$2"
    [ -z "$list" ] && return 1
    low_name=$(printf '%s' "$name" | tr 'A-Z' 'a-z')
    OLDIFS="$IFS"
    IFS=','
    for item in $list; do
        item=$(printf '%s' "$item" | sed 's/^ *//;s/ *$//')
        [ -z "$item" ] && continue
        low_item=$(printf '%s' "$item" | tr 'A-Z' 'a-z')
        case "$low_name" in
            *"$low_item"*) IFS="$OLDIFS"; return 0 ;;
        esac
    done
    IFS="$OLDIFS"
    return 1
}

cmd_config_get() {
    load_conf
    printf '{'
    printf '"enabled":%s,' "$ENABLED"
    printf '"target_section":"%s",' "$(json_escape "$TARGET_SECTION")"
    printf '"mode":"%s",' "$(json_escape "$MODE")"
    printf '"limit":%s,' "$LIMIT"
    printf '"use_ping_filter":%s,' "$USE_PING_FILTER"
    printf '"max_ping":%s,' "$MAX_PING"
    printf '"use_transport_filter":%s,' "$USE_TRANSPORT_FILTER"
    printf '"transports":"%s",' "$(json_escape "$TRANSPORTS")"
    printf '"use_proto_filter":%s,' "$USE_PROTO_FILTER"
    printf '"protocols":"%s",' "$(json_escape "$PROTOCOLS")"
    printf '"use_country_filter":%s,' "$USE_COUNTRY_FILTER"
    printf '"countries":"%s",' "$(json_escape "$COUNTRIES")"
    printf '"restart_podkop":%s' "$RESTART_PODKOP"
    printf '}\n'
}

cmd_config_set() {
    mkdir -p "$DATA_DIR"

    ENABLED="$1"
    TARGET_SECTION="$2"
    MODE="$3"
    LIMIT="$4"
    USE_PING_FILTER="$5"
    MAX_PING="$6"
    USE_TRANSPORT_FILTER="$7"
    TRANSPORTS="$8"
    USE_PROTO_FILTER="$9"
    PROTOCOLS="${10}"
    USE_COUNTRY_FILTER="${11}"
    COUNTRIES="${12}"
    RESTART_PODKOP="${13}"

    case "$ENABLED" in 0|1) ;; *) ENABLED=0 ;; esac
    case "$MODE" in replace|append) ;; *) MODE=replace ;; esac
    case "$LIMIT" in ''|*[!0-9]*) LIMIT=20 ;; esac
    case "$MAX_PING" in ''|*[!0-9]*) MAX_PING=700 ;; esac
    case "$USE_PING_FILTER" in 0|1) ;; *) USE_PING_FILTER=1 ;; esac
    case "$USE_TRANSPORT_FILTER" in 0|1) ;; *) USE_TRANSPORT_FILTER=0 ;; esac
    case "$USE_PROTO_FILTER" in 0|1) ;; *) USE_PROTO_FILTER=0 ;; esac
    case "$USE_COUNTRY_FILTER" in 0|1) ;; *) USE_COUNTRY_FILTER=0 ;; esac
    case "$RESTART_PODKOP" in 0|1) ;; *) RESTART_PODKOP=1 ;; esac

    cat > "$CONF" <<CONF_SET
ENABLED=$ENABLED
TARGET_SECTION=$TARGET_SECTION
MODE=$MODE
LIMIT=$LIMIT
USE_PING_FILTER=$USE_PING_FILTER
MAX_PING=$MAX_PING
USE_TRANSPORT_FILTER=$USE_TRANSPORT_FILTER
TRANSPORTS=$TRANSPORTS
USE_PROTO_FILTER=$USE_PROTO_FILTER
PROTOCOLS=$PROTOCOLS
USE_COUNTRY_FILTER=$USE_COUNTRY_FILTER
COUNTRIES=$COUNTRIES
RESTART_PODKOP=$RESTART_PODKOP
CONF_SET

    log "AutoAdd config saved: enabled=$ENABLED target=$TARGET_SECTION mode=$MODE limit=$LIMIT"
    echo "OK"
}

cmd_run() {
    load_conf

    if [ "$ENABLED" != "1" ]; then
        log "AutoAdd disabled"
        echo "SKIP: disabled"
        return 0
    fi

    if [ ! -f "$SERVERS_FILE" ] || [ ! -s "$SERVERS_FILE" ]; then
        log "AutoAdd: servers.json missing"
        echo "ERROR: no servers"
        return 1
    fi

    if [ ! -f "$LINKS_FILE" ]; then
        log "AutoAdd: links.txt missing"
        echo "ERROR: no links"
        return 1
    fi

    if [ -z "$(uci -q get "podkop.${TARGET_SECTION}" 2>/dev/null)" ]; then
        log "AutoAdd: target section not found: $TARGET_SECTION"
        echo "ERROR: target not found"
        return 1
    fi

    local ptype list_key added checked passed link id proto name type ping_json status ms current tmp_selected
    ptype=$(uci -q get "podkop.${TARGET_SECTION}.proxy_config_type" 2>/dev/null)
    case "$ptype" in
        selector) list_key="selector_proxy_links" ;;
        url) list_key="proxy_string" ;;
        *) list_key="urltest_proxy_links" ;;
    esac

    tmp_selected="/tmp/sub-sync-autoadd-selected.$$"
    : > "$tmp_selected"

    checked=0
    passed=0

    grep '"id":' "$SERVERS_FILE" | while IFS= read -r obj; do
        id=$(get_json_num "$obj" id)
        proto=$(get_json_field "$obj" proto)
        name=$(get_json_field "$obj" name)
        type=$(get_json_field "$obj" type)

        [ -z "$id" ] && continue
        checked=$((checked + 1))

        if [ "$USE_PROTO_FILTER" = "1" ] && ! csv_has "$PROTOCOLS" "$proto"; then
            continue
        fi

        if [ "$USE_TRANSPORT_FILTER" = "1" ] && ! csv_has "$TRANSPORTS" "$type"; then
            continue
        fi

        if [ "$USE_COUNTRY_FILTER" = "1" ] && ! csv_name_match "$COUNTRIES" "$name"; then
            continue
        fi

        if [ "$USE_PING_FILTER" = "1" ]; then
            ping_json=$("$REAL" ping "$id" 2>/dev/null || echo '{"status":"error","ms":0}')
            status=$(printf '%s' "$ping_json" | sed 's/.*"status":"\([^"]*\)".*/\1/')
            ms=$(printf '%s' "$ping_json" | sed 's/.*"ms":\([0-9][0-9]*\).*/\1/')
            [ "$status" = "ok" ] || continue
            case "$ms" in ''|*[!0-9]*) continue ;; esac
            [ "$ms" -le "$MAX_PING" ] || continue
        fi

        link=$("$REAL" link "$id" 2>/dev/null || true)
        case "$link" in
            vless://*|ss://*|trojan://*|hy2://*|hysteria2://*)
                printf '%s\n' "$link" >> "$tmp_selected"
                passed=$((passed + 1))
                ;;
        esac

        [ "$passed" -ge "$LIMIT" ] && break
    done

    added=$(grep -c '://' "$tmp_selected" 2>/dev/null || true)
    added=${added:-0}

    if [ "$added" = "0" ]; then
        rm -f "$tmp_selected"
        log "AutoAdd: no servers matched filters"
        echo "OK: 0"
        return 0
    fi

    if [ "$MODE" = "replace" ]; then
        case "$list_key" in
            proxy_string)
                :
                ;;
            *)
                uci -q delete "podkop.${TARGET_SECTION}.${list_key}" 2>/dev/null || true
                ;;
        esac
    fi

    if [ "$list_key" = "proxy_string" ]; then
        first_link=$(head -n 1 "$tmp_selected")
        uci set "podkop.${TARGET_SECTION}.proxy_string=${first_link}"
        added=1
    else
        while IFS= read -r link; do
            [ -z "$link" ] && continue
            if [ "$MODE" = "append" ]; then
                current=$(uci -q get "podkop.${TARGET_SECTION}.${list_key}" 2>/dev/null)
                printf '%s\n' "$current" | tr ' ' '\n' | grep -Fxq "$link" && continue
            fi
            uci add_list "podkop.${TARGET_SECTION}.${list_key}=${link}"
        done < "$tmp_selected"
    fi

    rm -f "$tmp_selected"

    uci commit podkop

    if [ "$RESTART_PODKOP" = "1" ]; then
        /etc/init.d/podkop restart 2>/dev/null || true
    fi

    log "AutoAdd: added $added server(s) to $TARGET_SECTION ($list_key), mode=$MODE"
    echo "OK: $added"
}

case "$1" in
    config-get) cmd_config_get ;;
    config-set) shift; cmd_config_set "$@" ;;
    run) cmd_run ;;
    *) echo "Usage: $0 config-get|config-set|run"; exit 1 ;;
esac
