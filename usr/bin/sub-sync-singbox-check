#!/bin/sh
# SUBSYNC_SINGBOX_CHECK_HELPER_V166
set -u

CONF="${1:-/etc/sing-box/config.json}"

if ! command -v sing-box >/dev/null 2>&1; then
  echo '{"ok":false,"error":"sing-box not found"}'
  exit 1
fi

OUT="$(sing-box check -c "$CONF" 2>&1)"
RC="$?"

if command -v jq >/dev/null 2>&1; then
  if [ "$RC" -eq 0 ]; then
    jq -n --arg conf "$CONF" --arg output "$OUT" '{ok:true,config:$conf,output:$output}'
  else
    jq -n --arg conf "$CONF" --arg output "$OUT" --argjson rc "$RC" '{ok:false,config:$conf,rc:$rc,output:$output}'
  fi
else
  [ "$RC" -eq 0 ] && echo "{\"ok\":true,\"config\":\"$CONF\"}" || echo "{\"ok\":false,\"config\":\"$CONF\",\"rc\":$RC}"
  [ -n "$OUT" ] && echo "$OUT"
fi

exit "$RC"
