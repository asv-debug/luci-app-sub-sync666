#!/bin/sh
# SUBSYNC_MANUAL_LINK_IMPORT_V167_LOCAL
set -u

LINK="${1:-${SUBSYNC_MANUAL_LINK:-}}"
NAME="${2:-${SUBSYNC_MANUAL_NAME:-Manual HY2}}"

mask_link() {
  printf '%s\n' "$1" | sed -E 's#^(vless|trojan|ss|hy2|hysteria2)://[^@]+@#\1://***@#'
}

[ -n "$LINK" ] || {
  echo "ERROR: no link. Usage: $0 'hy2://...' 'Manual HY2'"
  exit 1
}

case "$LINK" in
  vless://*|trojan://*|ss://*|hy2://*|hysteria2://*) ;;
  *)
    echo "ERROR: unsupported protocol. Use vless/trojan/ss/hy2/hysteria2"
    exit 1
    ;;
esac

[ -x /usr/bin/sub-sync-manual-link ] || {
  echo "ERROR: /usr/bin/sub-sync-manual-link not found"
  exit 1
}

echo "Adding manual server: $NAME"
echo "Link: $(mask_link "$LINK")"

/usr/bin/sub-sync-manual-link add-link "$LINK" "$NAME"
/usr/bin/sub-sync-manual-link merge

echo
echo "=== selectable URLTest servers ==="
[ -x /usr/bin/sub-sync-urltest ] && /usr/bin/sub-sync-urltest list || true

echo
echo "Manual link import done"
