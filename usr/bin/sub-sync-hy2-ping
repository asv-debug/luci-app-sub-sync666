#!/bin/sh
# SUBSYNC_HY2_PING_HELPER_V168K_BEGIN
set -u

CFG="/etc/sing-box/config.json"
ENC_URL="https%3A%2F%2Fwww.gstatic.com%2Fgenerate_204"

get_controller() {
  if command -v jq >/dev/null 2>&1; then
    jq -r '.experimental.clash_api.external_controller // empty' "$CFG" 2>/dev/null | head -n 1
  else
    sed -n 's/.*"external_controller"[ ]*:[ ]*"\([^"]*\)".*/\1/p' "$CFG" | head -n 1
  fi
}

CTRL="$(get_controller)"

if [ -z "$CTRL" ]; then
  echo "ERROR=clash_api external_controller not found"
  exit 2
fi

case "$CTRL" in
  http://*|https://*) BASE="$CTRL" ;;
  *) BASE="http://$CTRL" ;;
esac

echo "CTRL=$CTRL"

BEST_DELAY=""
BEST_TAG=""

for tag in zkssss324234-1-out zkssss324234-urltest-out zkssss324234-out; do
  out="$(wget -T 10 -qO- "$BASE/proxies/$tag/delay?timeout=8000&url=$ENC_URL" 2>/tmp/subsync-hy2-v168k.err || true)"
  delay="$(printf '%s' "$out" | sed -n 's/.*"delay"[ ]*:[ ]*\([0-9][0-9]*\).*/\1/p' | head -n 1)"

  if [ -n "$delay" ]; then
    echo "$tag=$delay"

    if [ -z "$BEST_DELAY" ] || [ "$delay" -lt "$BEST_DELAY" ]; then
      BEST_DELAY="$delay"
      BEST_TAG="$tag"
    fi
  else
    echo "$tag=ERR"
  fi
done

if [ -n "$BEST_DELAY" ]; then
  echo "BEST_TAG=$BEST_TAG"
  echo "BEST_DELAY=$BEST_DELAY"
  exit 0
fi

echo "ERROR=no delay from HY2 tags"
exit 1
# SUBSYNC_HY2_PING_HELPER_V168K_END
