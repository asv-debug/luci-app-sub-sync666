#!/bin/sh
# SUBSYNC_HY2_IMPORT_V168E_BEGIN
set -u

REAL="/usr/bin/sub-sync-manual-import.v167-before-v168d"
[ -x "$REAL" ] || REAL="/usr/bin/sub-sync-manual-import.v167-before-v168e"

SERVERS_JSON="/etc/sub-sync/servers.json"
MANUAL_STORE="/etc/sub-sync/manual-hy2.tsv"

cmd="${1:-list-hy2}"

is_hy2() {
  case "${1:-}" in
    hy2://*|hysteria2://*) return 0 ;;
    *) return 1 ;;
  esac
}

clean_name() {
  printf '%s' "${1:-Manual HY2}" | tr '\t\r\n' '   ' | sed 's/^ *//;s/ *$//'
}

clean_link() {
  printf '%s' "${1:-}" | tr -d '\r\n' | sed 's/^ *//;s/ *$//'
}

hash_link() {
  if command -v md5sum >/dev/null 2>&1; then
    printf '%s' "$1" | md5sum | awk '{print $1}'
  else
    printf '%s' "$1" | cksum | awk '{print $1}'
  fi
}

ensure_servers_json() {
  name="$(clean_name "${1:-Manual HY2}")"
  link="$(clean_link "${2:-}")"

  [ -n "$name" ] || name="Manual HY2"

  if ! is_hy2 "$link"; then
    echo "ERROR: not HY2 link. Use hy2:// or hysteria2://" >&2
    exit 2
  fi

  mkdir -p /etc/sub-sync

  if [ ! -s "$SERVERS_JSON" ]; then
    printf '[]\n' >"$SERVERS_JSON"
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "ERROR: jq not found, cannot safely update $SERVERS_JSON" >&2
    exit 3
  fi

  if ! jq -e 'type == "array"' "$SERVERS_JSON" >/dev/null 2>&1; then
    cp -a "$SERVERS_JSON" "$SERVERS_JSON.v168e-bad-$TS" 2>/dev/null || true
    printf '[]\n' >"$SERVERS_JSON"
  fi

  if jq -e --arg link "$link" '
    any(.[]?;
      (.link? == $link) or
      (.url? == $link) or
      (.raw? == $link) or
      (.uri? == $link)
    )
  ' "$SERVERS_JSON" >/dev/null 2>&1; then
    echo "OK: HY2 already exists in $SERVERS_JSON"
    exit 0
  fi

  id="manual_hy2_$(date +%s)_$(hash_link "$link" | cut -c1-8)"

  tmp="/tmp/subsync-servers-v168e-$$.json"

  jq \
    --arg id "$id" \
    --arg name "$name" \
    --arg link "$link" \
    '. + [{
      id: $id,
      name: $name,
      type: "hysteria2",
      protocol: "hysteria2",
      link: $link,
      url: $link,
      raw: $link,
      uri: $link,
      source: "manual-hy2-v168e",
      manual: true
    }]' "$SERVERS_JSON" >"$tmp"

  cp -a "$SERVERS_JSON" "$SERVERS_JSON.v168e-before-$(date +%Y%m%d-%H%M%S)" 2>/dev/null || true
  mv "$tmp" "$SERVERS_JSON"

  echo "OK: HY2 ensured in $SERVERS_JSON"
  echo "NAME=$name"
  echo "TYPE=hysteria2"
}

add_hy2() {
  name="$(clean_name "${2:-${SUBSYNC_MANUAL_NAME:-Manual HY2}}")"
  link="$(clean_link "${3:-${SUBSYNC_MANUAL_LINK:-}}")"

  [ -n "$name" ] || name="Manual HY2"

  if ! is_hy2 "$link"; then
    echo "ERROR: not HY2 link. Use hy2:// or hysteria2://" >&2
    exit 2
  fi

  export SUBSYNC_MANUAL_NAME="$name"
  export SUBSYNC_MANUAL_LINK="$link"
  export SUBSYNC_MANUAL_TYPE="hysteria2"

  mkdir -p /etc/sub-sync

  if [ -x "$REAL" ]; then
    "$REAL" add "$name" "$link" 2>/tmp/subsync-hy2-real.err && {
      cat /tmp/subsync-hy2-real.err 2>/dev/null || true
      echo "OK: added by original helper"
      printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "hysteria2" "$name" "$link" >>"$MANUAL_STORE"
      ensure_servers_json "$name" "$link"
      exit 0
    }

    SUBSYNC_MANUAL_NAME="$name" SUBSYNC_MANUAL_LINK="$link" SUBSYNC_MANUAL_TYPE="hysteria2" "$REAL" 2>/tmp/subsync-hy2-real-env.err && {
      cat /tmp/subsync-hy2-real-env.err 2>/dev/null || true
      echo "OK: added by original helper env"
      printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "hysteria2" "$name" "$link" >>"$MANUAL_STORE"
      ensure_servers_json "$name" "$link"
      exit 0
    }
  fi

  printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "hysteria2" "$name" "$link" >>"$MANUAL_STORE"

  echo "OK: added HY2 fallback"
  echo "STORE=$MANUAL_STORE"

  ensure_servers_json "$name" "$link"
}

list_hy2() {
  echo "### manual HY2 store"
  if [ -f "$MANUAL_STORE" ]; then
    cat "$MANUAL_STORE"
  else
    echo "empty: $MANUAL_STORE"
  fi

  echo
  echo "### servers.json HY2 entries"
  if [ -f "$SERVERS_JSON" ] && command -v jq >/dev/null 2>&1; then
    jq -r '
      .[]?
      | select(
          (.type? | tostring | test("hysteria2|hy2"; "i")) or
          (.protocol? | tostring | test("hysteria2|hy2"; "i")) or
          (.link? | tostring | test("^(hy2|hysteria2)://"; "i")) or
          (.url? | tostring | test("^(hy2|hysteria2)://"; "i")) or
          (.raw? | tostring | test("^(hy2|hysteria2)://"; "i")) or
          (.uri? | tostring | test("^(hy2|hysteria2)://"; "i"))
        )
      | [.name, (.type // .protocol // "hysteria2"), (.link // .url // .raw // .uri // "")] | @tsv
    ' "$SERVERS_JSON"
  else
    echo "no $SERVERS_JSON or jq missing"
  fi
}

case "$cmd" in
  add-hy2)
    add_hy2 "$@"
    ;;
  ensure-hy2)
    ensure_servers_json "${2:-Manual HY2}" "${3:-}"
    ;;
  list-hy2|list|show)
    list_hy2
    ;;
  add)
    # Совместимость: если пришла HY2 ссылка через старую кнопку, принимаем.
    add_hy2 "$@"
    ;;
  *)
    # Старый формат: /usr/bin/sub-sync-manual-import "Name" "hy2://..."
    if [ $# -ge 2 ]; then
      name="$1"
      link="$2"
      set -- add-hy2 "$name" "$link"
      add_hy2 "$@"
    else
      list_hy2
    fi
    ;;
esac
# SUBSYNC_HY2_IMPORT_V168E_END
