#!/bin/sh
# SUBSYNC_HY2_AUTOADD_TARGET_CLEAN_V176
# SUBSYNC_HY2_DELETE_EMPTY_LINK_V175
set -u

cmd="${1:-}"

mask() {
  printf '%s\n' "$1" | sed -E 's#^(hy2|hysteria2)://[^@[:space:]]+@#\1://***@#g'
}

is_hy2() {
  case "$1" in
    hy2://*|hysteria2://*) return 0 ;;
    *) return 1 ;;
  esac
}

clean_json_by_jq_filter() {
  f="$1"
  filter="$2"

  [ -f "$f" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq empty "$f" >/dev/null 2>&1 || return 0

  jq "$filter" "$f" > "$f.tmp"
  jq empty "$f.tmp"
  cp -f "$f.tmp" "$f"
  rm -f "$f.tmp"
}

remove_from_subsync_db() {
  link="${1:-}"
  [ -n "$link" ] || return 0

  echo
  echo "Remove exact HY2 from Sub Sync DB:"
  echo "Link: $(mask "$link")"

  for f in /etc/sub-sync/manual-links.tsv /etc/sub-sync/manual-hy2.tsv /etc/sub-sync/*.tsv /etc/sub-sync/*.txt; do
    [ -f "$f" ] || continue
    if grep -Fq "$link" "$f" 2>/dev/null; then
      echo "clean text: $f"
      awk -v link="$link" 'index($0, link) == 0 { print }' "$f" > "$f.tmp"
      mv "$f.tmp" "$f"
    fi
  done

  if command -v jq >/dev/null 2>&1; then
    for f in /etc/sub-sync/servers.json /etc/sub-sync/*.json; do
      [ -f "$f" ] || continue
      jq empty "$f" >/dev/null 2>&1 || continue
      if grep -Fq "$link" "$f" 2>/dev/null; then
        echo "clean json: $f"
        jq --arg link "$link" '
          def keep_link:
            if type == "object" then
              ((.link // .url // .raw // "") != $link)
            else true end;
          if type == "array" then
            map(select(keep_link))
          elif type == "object" and ((.servers // null) | type) == "array" then
            .servers |= map(select(keep_link))
          else . end
        ' "$f" > "$f.tmp"
        jq empty "$f.tmp"
        cp -f "$f.tmp" "$f"
        rm -f "$f.tmp"
      fi
    done
  fi
}

remove_all_hy2_from_subsync_db() {
  echo
  echo "Remove ALL HY2/HYSTERIA2 from Sub Sync DB because delete link is empty"

  for f in /etc/sub-sync/manual-links.tsv /etc/sub-sync/manual-hy2.tsv /etc/sub-sync/*.tsv /etc/sub-sync/*.txt; do
    [ -f "$f" ] || continue
    if grep -Eiq '(^|[[:space:]])(hy2|hysteria2)://' "$f" 2>/dev/null; then
      echo "clean text HY2: $f"
      awk 'tolower($0) !~ /(hy2|hysteria2):\/\//' "$f" > "$f.tmp"
      mv "$f.tmp" "$f"
    fi
  done

  if command -v jq >/dev/null 2>&1; then
    for f in /etc/sub-sync/servers.json /etc/sub-sync/*.json; do
      [ -f "$f" ] || continue
      jq empty "$f" >/dev/null 2>&1 || continue

      if grep -Eiq 'hysteria2|hy2://' "$f" 2>/dev/null; then
        echo "clean json HY2: $f"
        jq '
          def is_hy2_obj:
            if type == "object" then
              (((.proto // .protocol // .scheme // "") | ascii_downcase) == "hy2") or
              (((.proto // .protocol // .scheme // "") | ascii_downcase) == "hysteria2") or
              (((.link // .url // .raw // "") | ascii_downcase) | startswith("hy2://")) or
              (((.link // .url // .raw // "") | ascii_downcase) | startswith("hysteria2://"))
            else false end;

          if type == "array" then
            map(select(is_hy2_obj | not))
          elif type == "object" and ((.servers // null) | type) == "array" then
            .servers |= map(select(is_hy2_obj | not))
          else . end
        ' "$f" > "$f.tmp"
        jq empty "$f.tmp"
        cp -f "$f.tmp" "$f"
        rm -f "$f.tmp"
      fi
    done
  fi
}

select_hy2() {
  section="${1:-}"
  name="${2:-Manual HY2}"
  link="${3:-}"

  [ -n "$section" ] || { echo "ERROR: section empty"; exit 1; }
  [ -n "$link" ] || { echo "ERROR: link empty"; exit 1; }
  is_hy2 "$link" || { echo "ERROR: only hy2:// or hysteria2://"; exit 1; }

  case "$section" in
    *[!A-Za-z0-9_]*)
      echo "ERROR: section name only A-Z a-z 0-9 _"
      exit 1
    ;;
  esac

  echo "Import HY2:"
  echo "Name: $name"
  echo "Link: $(mask "$link")"

  /usr/bin/sub-sync-manual-link add-link "$link" "$name" || true
  /usr/bin/sub-sync-manual-link merge || true

  echo
  echo "Apply via sub-sync-urltest apply-link:"
  /usr/bin/sub-sync-urltest apply-link "$section" "$link"

  echo
  echo "Restart Podkop..."
  /etc/init.d/podkop restart || true
  sleep 5

  echo
  echo "=== podkop.$section ==="
  uci -q show "podkop.$section" | sed -E 's#(hy2|hysteria2)://[^@[:space:]]+@#\1://***@#g' || true

  echo
  echo "=== config HY2 markers ==="
  grep -nE '"type": "hysteria2"|hysteria2|hy2|urltest' /etc/sing-box/config.json 2>/dev/null | head -120 || true

  echo
  echo "=== sing-box check ==="
  sing-box check -c /etc/sing-box/config.json

  echo
  echo "DONE select HY2"
}

delete_hy2() {
  section="${1:-}"
  link="${2:-}"

  [ -n "$section" ] || { echo "ERROR: section empty"; exit 1; }

  tmp="/tmp/subsync-hy2-delete-links.$$"
  : > "$tmp"

  echo "Delete HY2 from section: $section"
  [ -n "$link" ] && echo "Link: $(mask "$link")"

  if [ -n "$link" ]; then
    echo "$link" >> "$tmp"
    uci -q del_list "podkop.$section.urltest_proxy_links=$link" || true
  else
    uci -q show podkop \
      | sed -n "s/^\(podkop\.$section\.urltest_proxy_links\)='\(.*\)'$/\1|\2/p" \
      | while IFS='|' read -r opt val; do
          case "$val" in
            hy2://*|hysteria2://*)
              echo "remove: $opt=$(mask "$val")"
              echo "$val" >> "$tmp"
              uci -q del_list "$opt=$val" || true
            ;;
          esac
        done
  fi

  if [ -s "$tmp" ]; then
    sort -u "$tmp" | while IFS= read -r l; do
      [ -n "$l" ] && remove_from_subsync_db "$l"
    done
  else
    remove_all_hy2_from_subsync_db
  fi
  rm -f "$tmp"

  left="$(uci -q get "podkop.$section.urltest_proxy_links" 2>/dev/null || true)"
  if [ -z "$left" ]; then
    echo "Section $section has no urltest_proxy_links, delete empty test section"
    uci -q delete "podkop.$section" 2>/dev/null || true
    if [ -f /etc/sub-sync/autoadd.conf ] && grep -q "^TARGET_SECTION=$section$" /etc/sub-sync/autoadd.conf; then
      echo "AutoAdd target was deleted section $section, reset to byzks95"
      sed -i "s/^TARGET_SECTION=.*/TARGET_SECTION=byzks95/" /etc/sub-sync/autoadd.conf
    fi
  fi

  uci commit podkop

  echo
  echo "Restart Podkop..."
  /etc/init.d/podkop restart || true
  sleep 6

  echo
  echo "=== HY2 must be absent from sing-box ==="
  grep -nE '"type": "hysteria2"|hysteria2|hy2|se2\.belka\.network' /etc/sing-box/config.json 2>/dev/null || echo "OK: no HY2 in sing-box"

  echo
  echo "=== HY2 must be absent from Sub Sync DB ==="
  grep -RsnEi 'hysteria2|hy2://|Manual HY2|Manual HY222|se2\.belka\.network' /etc/sub-sync 2>/dev/null \
    | sed -E 's#(hy2|hysteria2)://[^@[:space:]]+@#\1://***@#g' || echo "OK: no HY2 in /etc/sub-sync"

  echo
  echo "=== selectable servers ==="
  /usr/bin/sub-sync-urltest list 2>/dev/null | sed -E 's#(hy2|hysteria2)://[^@[:space:]]+@#\1://***@#g' || true

  echo
  echo "=== sing-box check ==="
  sing-box check -c /etc/sing-box/config.json

  echo
  echo "DONE delete HY2"
}

case "$cmd" in
  select) select_hy2 "${2:-}" "${3:-Manual HY2}" "${4:-}" ;;
  delete) delete_hy2 "${2:-}" "${3:-}" ;;
  list) /usr/bin/sub-sync-urltest list ;;
  check) sing-box check -c /etc/sing-box/config.json ;;
  *)
    echo "Usage:"
    echo "  $0 select SECTION 'Manual HY2' 'hysteria2://...'"
    echo "  $0 delete SECTION 'hysteria2://...'"
    echo "  $0 list"
    echo "  $0 check"
    exit 1
  ;;
esac
