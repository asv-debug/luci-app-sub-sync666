#!/bin/sh
# SUBSYNC_HY2_MANAGER_SELF_CONTAINED_V197
set -eu

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ok_msg() {
  printf '{"ok":true,"message":"%s"}\n' "$(json_escape "$1")"
}

err_msg() {
  printf '{"ok":false,"error":"%s"}\n' "$(json_escape "$1")"
}

is_hy2() {
  case "${1:-}" in
    hy2://*|hysteria2://*) return 0 ;;
    *) return 1 ;;
  esac
}

cmd="${1:-list}"

case "$cmd" in
  select)
    section="${2:-}"
    name="${3:-Manual HY2}"
    link="${4:-}"

    [ -n "$section" ] || { err_msg "Не указана Podkop-секция"; exit 0; }
    is_hy2 "$link" || { err_msg "Вставь полную ссылку hy2:// или hysteria2://"; exit 0; }

    if [ -x /usr/bin/sub-sync-urltest ]; then
      out="$(/usr/bin/sub-sync-urltest apply-link "$section" "$link" 2>&1)" || {
        err_msg "$out"
        exit 0
      }
      /etc/init.d/podkop restart >/dev/null 2>&1 || true
      ok_msg "HY2 применён в секцию $section. $out"
      exit 0
    fi

    err_msg "/usr/bin/sub-sync-urltest not found"
  ;;

  delete)
    section="${2:-}"
    link="${3:-}"

    [ -n "$section" ] || { err_msg "Не указана Podkop-секция"; exit 0; }
    is_hy2 "$link" || { err_msg "Нет HY2 ключа — удалять нечего. Вставь hy2:// или hysteria2://."; exit 0; }

    cur="$(uci -q get "podkop.$section.urltest_proxy_links" 2>/dev/null || true)"
    new=""
    for x in $cur; do
      [ "$x" = "$link" ] && continue
      new="$new $x"
    done

    uci set "podkop.$section.urltest_proxy_links=$new"
    uci commit podkop
    /etc/init.d/podkop restart >/dev/null 2>&1 || true
    ok_msg "HY2 удалён из секции $section"
  ;;

  check)
    if sing-box check -c /etc/sing-box/config.json >/tmp/subsync-hy2-check.out 2>&1; then
      ok_msg "sing-box config OK"
    else
      err_msg "$(cat /tmp/subsync-hy2-check.out)"
    fi
  ;;

  list)
    if [ -f /etc/sub-sync/servers.json ]; then
      jq -c '[.[] | select(((.proto // "")|ascii_downcase)=="hy2" or ((.proto // "")|ascii_downcase)=="hysteria2" or ((.type // "")|ascii_downcase)=="hysteria2")]' /etc/sub-sync/servers.json 2>/dev/null || echo '[]'
    else
      echo '[]'
    fi
  ;;

  *)
    err_msg "Unknown command: $cmd"
  ;;
esac
