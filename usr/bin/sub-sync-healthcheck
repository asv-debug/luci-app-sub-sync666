#!/bin/sh
# SUBSYNC_HEALTHCHECK_FAILOVER_V458
set -u

DATA="/etc/sub-sync"
CFG="$DATA/healthcheck.conf"
STATE="$DATA/healthcheck-state.json"
LINKS="$DATA/links.txt"
CRON="/etc/crontabs/root"
LOCK="/tmp/subsync-healthcheck.lock"
LOG_TAG="sub-sync-healthcheck"

DEFAULT_ENABLED="0"
DEFAULT_SECTION="main"
DEFAULT_MODE="replace"
DEFAULT_INTERVAL="5"
DEFAULT_TARGET="https://www.gstatic.com/generate_204"
DEFAULT_FAIL_THRESHOLD="2"
DEFAULT_TIMEOUT="8"
DEFAULT_MAX_PING="1200"
DEFAULT_LIMIT="25"
DEFAULT_SYNC_BEFORE_SWITCH="0"

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g;s/"/\\"/g' | tr -d '\r' | tr '\n' ' '
}

log_msg() {
  logger -t "$LOG_TAG" "$1" 2>/dev/null || true
  echo "$(date '+%Y-%m-%d %H:%M:%S') $1"
}

num_or() {
  v="${1:-}"
  d="${2:-0}"
  case "$v" in
    ''|*[!0-9]*) printf '%s' "$d" ;;
    *) printf '%s' "$v" ;;
  esac
}

safe_section() {
  case "$1" in
    ''|*[!A-Za-z0-9_]*)
      return 1
      ;;
  esac
  return 0
}

ensure_cfg() {
  mkdir -p "$DATA"
  [ -f "$CFG" ] && return 0
  {
    echo "enabled=$DEFAULT_ENABLED"
    echo "section=$DEFAULT_SECTION"
    echo "mode=$DEFAULT_MODE"
    echo "interval=$DEFAULT_INTERVAL"
    echo "target=$DEFAULT_TARGET"
    echo "fail_threshold=$DEFAULT_FAIL_THRESHOLD"
    echo "timeout=$DEFAULT_TIMEOUT"
    echo "max_ping=$DEFAULT_MAX_PING"
    echo "limit=$DEFAULT_LIMIT"
    echo "sync_before_switch=$DEFAULT_SYNC_BEFORE_SWITCH"
  } > "$CFG"
}

cfg_get() {
  key="$1"
  def="$2"
  val="$(grep -E "^${key}=" "$CFG" 2>/dev/null | tail -n 1 | cut -d= -f2-)"
  [ -n "$val" ] || val="$def"
  printf '%s' "$val"
}

state_fail_count() {
  sed -n 's/.*"fail_count"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$STATE" 2>/dev/null | head -n 1
}

write_state() {
  st="$1"
  msg="$2"
  fails="$(num_or "${3:-0}" 0)"
  selected_id="$(num_or "${4:-0}" 0)"
  selected_ms="$(num_or "${5:-0}" 0)"
  section="${6:-$(cfg_get section "$DEFAULT_SECTION")}"
  target="${7:-$(cfg_get target "$DEFAULT_TARGET")}"
  now="$(date '+%Y-%m-%d %H:%M:%S')"
  mkdir -p "$DATA"
  printf '{"status":"%s","message":"%s","fail_count":%s,"selected_id":%s,"selected_ms":%s,"section":"%s","target":"%s","time":"%s"}\n' \
    "$(json_escape "$st")" \
    "$(json_escape "$msg")" \
    "$fails" "$selected_id" "$selected_ms" \
    "$(json_escape "$section")" \
    "$(json_escape "$target")" \
    "$(json_escape "$now")" > "$STATE"
}

cron_apply() {
  enabled="$1"
  interval="$(num_or "$2" "$DEFAULT_INTERVAL")"
  [ "$interval" -ge 1 ] 2>/dev/null || interval="$DEFAULT_INTERVAL"
  [ "$interval" -le 59 ] 2>/dev/null || interval="59"

  mkdir -p /etc/crontabs
  touch "$CRON"
  tmp="/tmp/subsync-healthcheck-cron.$$"
  grep -v '/usr/bin/sub-sync-healthcheck run' "$CRON" > "$tmp" 2>/dev/null || true

  if [ "$enabled" = "1" ]; then
    printf '*/%s * * * * /usr/bin/sub-sync-healthcheck run >/tmp/subsync-healthcheck-last.log 2>&1\n' "$interval" >> "$tmp"
  fi

  cp -f "$tmp" "$CRON"
  rm -f "$tmp"
  /etc/init.d/cron restart >/dev/null 2>&1 || true
}

cmd_config_get() {
  ensure_cfg
  printf '{"enabled":"%s","section":"%s","mode":"%s","interval":"%s","target":"%s","fail_threshold":"%s","timeout":"%s","max_ping":"%s","limit":"%s","sync_before_switch":"%s"}\n' \
    "$(json_escape "$(cfg_get enabled "$DEFAULT_ENABLED")")" \
    "$(json_escape "$(cfg_get section "$DEFAULT_SECTION")")" \
    "$(json_escape "$(cfg_get mode "$DEFAULT_MODE")")" \
    "$(json_escape "$(cfg_get interval "$DEFAULT_INTERVAL")")" \
    "$(json_escape "$(cfg_get target "$DEFAULT_TARGET")")" \
    "$(json_escape "$(cfg_get fail_threshold "$DEFAULT_FAIL_THRESHOLD")")" \
    "$(json_escape "$(cfg_get timeout "$DEFAULT_TIMEOUT")")" \
    "$(json_escape "$(cfg_get max_ping "$DEFAULT_MAX_PING")")" \
    "$(json_escape "$(cfg_get limit "$DEFAULT_LIMIT")")" \
    "$(json_escape "$(cfg_get sync_before_switch "$DEFAULT_SYNC_BEFORE_SWITCH")")"
}

cmd_status() {
  ensure_cfg
  if [ -s "$STATE" ]; then
    cat "$STATE"
  else
    write_state "idle" "healthcheck has not run yet" 0 0 0 "$(cfg_get section "$DEFAULT_SECTION")" "$(cfg_get target "$DEFAULT_TARGET")"
    cat "$STATE"
  fi
}

cmd_config_set() {
  ensure_cfg
  enabled="${1:-$DEFAULT_ENABLED}"
  section="${2:-$DEFAULT_SECTION}"
  mode="${3:-$DEFAULT_MODE}"
  interval="$(num_or "${4:-$DEFAULT_INTERVAL}" "$DEFAULT_INTERVAL")"
  target="${5:-$DEFAULT_TARGET}"
  fail_threshold="$(num_or "${6:-$DEFAULT_FAIL_THRESHOLD}" "$DEFAULT_FAIL_THRESHOLD")"
  timeout="$(num_or "${7:-$DEFAULT_TIMEOUT}" "$DEFAULT_TIMEOUT")"
  max_ping="$(num_or "${8:-$DEFAULT_MAX_PING}" "$DEFAULT_MAX_PING")"
  limit="$(num_or "${9:-$DEFAULT_LIMIT}" "$DEFAULT_LIMIT")"
  sync_before_switch="${10:-$DEFAULT_SYNC_BEFORE_SWITCH}"

  [ "$enabled" = "1" ] || enabled="0"
  [ "$mode" = "append" ] || mode="replace"
  safe_section "$section" || { echo '{"ok":0,"error":"bad_section"}'; return 1; }
  [ -n "$target" ] || target="$DEFAULT_TARGET"
  [ "$interval" -ge 1 ] 2>/dev/null || interval="$DEFAULT_INTERVAL"
  [ "$interval" -le 59 ] 2>/dev/null || interval="59"
  [ "$fail_threshold" -ge 1 ] 2>/dev/null || fail_threshold="$DEFAULT_FAIL_THRESHOLD"
  [ "$timeout" -ge 1 ] 2>/dev/null || timeout="$DEFAULT_TIMEOUT"
  [ "$max_ping" -ge 1 ] 2>/dev/null || max_ping="$DEFAULT_MAX_PING"
  [ "$limit" -ge 1 ] 2>/dev/null || limit="$DEFAULT_LIMIT"
  [ "$limit" -le 200 ] 2>/dev/null || limit="200"
  [ "$sync_before_switch" = "1" ] || sync_before_switch="0"

  {
    echo "enabled=$enabled"
    echo "section=$section"
    echo "mode=$mode"
    echo "interval=$interval"
    echo "target=$target"
    echo "fail_threshold=$fail_threshold"
    echo "timeout=$timeout"
    echo "max_ping=$max_ping"
    echo "limit=$limit"
    echo "sync_before_switch=$sync_before_switch"
  } > "$CFG"

  cron_apply "$enabled" "$interval"
  printf '{"ok":1,"enabled":"%s","interval":"%s"}\n' "$enabled" "$interval"
}

probe_target() {
  target="$1"
  timeout="$(num_or "$2" "$DEFAULT_TIMEOUT")"

  case "$target" in
    http://*|https://*)
      if command -v curl >/dev/null 2>&1; then
        code="$(curl -k -L -s -o /dev/null -w '%{http_code}' --connect-timeout "$timeout" --max-time "$timeout" "$target" 2>/dev/null || echo 000)"
        case "$code" in
          2*|3*) return 0 ;;
        esac
        return 1
      fi
      tmp="/tmp/subsync-healthcheck-probe.$$"
      if wget -q -T "$timeout" -O "$tmp" "$target" >/dev/null 2>&1; then
        rm -f "$tmp"
        return 0
      fi
      rm -f "$tmp"
      return 1
      ;;
    *)
      host="$target"
      host="${host#http://}"
      host="${host#https://}"
      host="${host%%/*}"
      host="${host%%:*}"
      [ -n "$host" ] || return 1
      ping -c 1 -W "$timeout" "$host" >/dev/null 2>&1
      return "$?"
      ;;
  esac
}

current_links_file() {
  sec="$1"
  file="$2"
  : > "$file"
  ptype="$(uci -q get "podkop.$sec.proxy_config_type" 2>/dev/null || true)"
  case "$ptype" in
    url)
      uci -q get "podkop.$sec.proxy_string" 2>/dev/null | tr ' ' '\n' >> "$file" || true
      ;;
    selector)
      uci -q get "podkop.$sec.selector_proxy_links" 2>/dev/null | tr ' ' '\n' >> "$file" || true
      ;;
    *)
      uci -q get "podkop.$sec.urltest_proxy_links" 2>/dev/null | tr ' ' '\n' >> "$file" || true
      ;;
  esac
}

ensure_links_cache() {
  sync_before_switch="$1"
  if [ -s "$LINKS" ] && [ -s "$DATA/servers.json" ]; then
    return 0
  fi
  [ "$sync_before_switch" = "1" ] || return 1
  /usr/bin/sub-sync sync >/tmp/subsync-healthcheck-sync.log 2>&1 || true
  [ -s "$LINKS" ] && [ -s "$DATA/servers.json" ]
}

section_or_first() {
  sec="$1"
  if uci -q show "podkop.$sec" >/dev/null 2>&1; then
    printf '%s' "$sec"
    return 0
  fi
  first="$(uci show podkop 2>/dev/null | sed -n 's/^podkop\.\([^.=]*\)=section.*/\1/p' | head -n 1)"
  [ -n "$first" ] && printf '%s' "$first"
}

pick_best() {
  skip_current="$1"
  current_file="$2"
  max_ping="$(num_or "$3" "$DEFAULT_MAX_PING")"
  limit="$(num_or "$4" "$DEFAULT_LIMIT")"

  id=0
  checked=0
  best_id=""
  best_ms=999999

  while IFS= read -r link; do
    link="$(printf '%s' "$link" | tr -d '\r')"
    case "$link" in
      vless://*|ss://*|trojan://*|hy2://*|hysteria2://*) ;;
      *) continue ;;
    esac

    id=$((id + 1))
    if [ "$skip_current" = "1" ] && grep -Fxq "$link" "$current_file" 2>/dev/null; then
      continue
    fi

    [ "$checked" -lt "$limit" ] || break
    checked=$((checked + 1))

    res="$(/usr/bin/sub-sync ping "$id" 2>/dev/null || true)"
    st="$(printf '%s' "$res" | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
    ms="$(printf '%s' "$res" | sed -n 's/.*"ms"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1)"
    ms="$(num_or "$ms" 0)"

    if [ "$st" = "ok" ] && [ "$ms" -gt 0 ] && [ "$ms" -le "$max_ping" ] && [ "$ms" -lt "$best_ms" ]; then
      best_id="$id"
      best_ms="$ms"
    fi
  done < "$LINKS"

  [ -n "$best_id" ] || return 1
  printf '%s %s %s\n' "$best_id" "$best_ms" "$checked"
}

switch_server() {
  ensure_cfg
  section_cfg="$(cfg_get section "$DEFAULT_SECTION")"
  mode="$(cfg_get mode "$DEFAULT_MODE")"
  max_ping="$(cfg_get max_ping "$DEFAULT_MAX_PING")"
  limit="$(cfg_get limit "$DEFAULT_LIMIT")"
  sync_before_switch="$(cfg_get sync_before_switch "$DEFAULT_SYNC_BEFORE_SWITCH")"

  section="$(section_or_first "$section_cfg")"
  if [ -z "$section" ]; then
    echo "ERROR: no podkop section found"
    return 1
  fi

  if ! ensure_links_cache "$sync_before_switch"; then
    echo "ERROR: no server cache. Run /usr/bin/sub-sync sync first"
    return 1
  fi

  cur="/tmp/subsync-healthcheck-current.$$"
  current_links_file "$section" "$cur"

  pick="$(pick_best 1 "$cur" "$max_ping" "$limit" 2>/dev/null || true)"
  if [ -z "$pick" ]; then
    pick="$(pick_best 0 "$cur" "$max_ping" "$limit" 2>/dev/null || true)"
  fi
  rm -f "$cur"

  if [ -z "$pick" ]; then
    echo "ERROR: no reachable server within max_ping=${max_ping}ms"
    return 1
  fi

  set -- $pick
  best_id="$1"
  best_ms="$2"

  out="$(/usr/bin/sub-sync-autoadd apply-ids "$section" "$mode" "$best_id" 2>&1)"
  rc="$?"
  echo "$out"
  [ "$rc" = "0" ] || return "$rc"

  write_state "switched" "target failed; switched server" 0 "$best_id" "$best_ms" "$section" "$(cfg_get target "$DEFAULT_TARGET")"
  log_msg "Switched $section to server id=$best_id ping=${best_ms}ms mode=$mode"
  return 0
}

cmd_run() {
  force="${1:-}"
  ensure_cfg

  if ! mkdir "$LOCK" 2>/dev/null; then
    write_state "locked" "previous healthcheck is still running" "$(num_or "$(state_fail_count)" 0)" 0 0 "$(cfg_get section "$DEFAULT_SECTION")" "$(cfg_get target "$DEFAULT_TARGET")"
    exit 0
  fi
  trap 'rmdir "$LOCK" 2>/dev/null || true' EXIT

  enabled="$(cfg_get enabled "$DEFAULT_ENABLED")"
  if [ "$enabled" != "1" ] && [ "$force" != "force" ]; then
    write_state "disabled" "healthcheck disabled" 0 0 0 "$(cfg_get section "$DEFAULT_SECTION")" "$(cfg_get target "$DEFAULT_TARGET")"
    exit 0
  fi

  section="$(cfg_get section "$DEFAULT_SECTION")"
  target="$(cfg_get target "$DEFAULT_TARGET")"
  timeout="$(cfg_get timeout "$DEFAULT_TIMEOUT")"
  threshold="$(cfg_get fail_threshold "$DEFAULT_FAIL_THRESHOLD")"
  threshold="$(num_or "$threshold" "$DEFAULT_FAIL_THRESHOLD")"
  old_fails="$(num_or "$(state_fail_count)" 0)"

  if probe_target "$target" "$timeout"; then
    write_state "ok" "target is reachable" 0 0 0 "$section" "$target"
    log_msg "Target reachable: $target"
    exit 0
  fi

  fails=$((old_fails + 1))
  if [ "$fails" -lt "$threshold" ]; then
    write_state "fail" "target is not reachable; waiting for threshold" "$fails" 0 0 "$section" "$target"
    log_msg "Target failed $fails/$threshold: $target"
    exit 0
  fi

  log_msg "Target failed $fails/$threshold, switching server: $target"
  if switch_server >/tmp/subsync-healthcheck-switch.log 2>&1; then
    exit 0
  fi

  err="$(cat /tmp/subsync-healthcheck-switch.log 2>/dev/null | tail -n 3 | tr '\n' ' ')"
  [ -n "$err" ] || err="switch failed"
  write_state "error" "$err" "$fails" 0 0 "$section" "$target"
  log_msg "$err"
  exit 1
}

cmd_probe() {
  ensure_cfg
  target="${1:-$(cfg_get target "$DEFAULT_TARGET")}"
  timeout="$(cfg_get timeout "$DEFAULT_TIMEOUT")"
  if probe_target "$target" "$timeout"; then
    echo '{"ok":1}'
  else
    echo '{"ok":0}'
    return 1
  fi
}

ensure_cfg

cmd="${1:-status}"
shift || true

case "$cmd" in
  config-get) cmd_config_get ;;
  config-set) cmd_config_set "$@" ;;
  status) cmd_status ;;
  run) cmd_run "${1:-}" ;;
  switch) switch_server ;;
  probe) cmd_probe "${1:-}" ;;
  cron-apply) cron_apply "$(cfg_get enabled "$DEFAULT_ENABLED")" "$(cfg_get interval "$DEFAULT_INTERVAL")" ;;
  *)
    echo "Usage: $0 {config-get|config-set|status|run [force]|switch|probe [target]|cron-apply}"
    exit 1
    ;;
esac
